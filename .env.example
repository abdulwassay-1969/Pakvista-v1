# -----------------------------------------------------------------------------
# AI & SMART PLANNER (Google Gemini via Genkit)
# Create a key: https://aistudio.google.com/apikey
# -----------------------------------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_MODEL=googleai/gemini-2.5-flash

# -----------------------------------------------------------------------------
# TRAVELER GALLERY (Firebase Storage & Firestore)
# Create a project: https://console.firebase.google.com/
# -----------------------------------------------------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=your_measurement_id

# -----------------------------------------------------------------------------
# TRAVELER GALLERY (ImageKit for Storage, Firebase for Metadata)
# Create a free account (no card): https://imagekit.io/
# -----------------------------------------------------------------------------
IMAGEKIT_PUBLIC_KEY=your_imagekit_public_key
IMAGEKIT_PRIVATE_KEY=your_imagekit_private_key
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_id

# -----------------------------------------------------------------------------
# WEATHER DATA (Meteoblue)
# Create a key: https://www.meteoblue.com/en/products/weatherapi
# -----------------------------------------------------------------------------
METEOBLUE_API_KEY=your_meteoblue_api_key_here
